[run]
source = core_apps
omit = 
    */migrations/*
    */tests/*
    */test_*.py
    */__pycache__/*
    */admin.py
    */apps.py
    */urls.py
    */wsgi.py
    */asgi.py
    */celery_app.py
    */settings/*
    */manage.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
precision = 2
show_missing = True
skip_covered = False

[html]
directory = htmlcov

